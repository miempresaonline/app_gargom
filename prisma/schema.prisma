generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id               Int       @id @default(autoincrement())
  presupuestoTotal Float
  direccion        String
  nombreReferencia String?
  arquitecto         String?
  arquitectoCorreo   String?
  arquitectoTelefono String?
  
  aparejador         String?
  aparejadorCorreo   String?
  aparejadorTelefono String?
  
  cliente            String
  clienteCorreo      String?
  clienteTelefono    String?
  observaciones    String?   @db.Text
  
  presupuestoAdicional Float @default(0)
  porcentajeImpuesto   Float @default(10)
  estado               String @default("ACTIVA")

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  expenses         Expense[]
  certifications   Certification[]
  clients          ProjectClient[]
}

model ProjectClient {
  id                    Int      @id @default(autoincrement())
  nombre                String
  cif                   String?
  direccion             String?
  porcentajeFacturacion Float?   @default(100)
  
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Worker {
  id         Int       @id @default(autoincrement())
  nombre     String
  cargo      String
  precioHora Float
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  expenses   Expense[]
}

model Bank {
  id           Int       @id @default(autoincrement())
  nombre       String
  numeroCuenta String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  expenses     Expense[]
}

model Supplier {
  id        Int      @id @default(autoincrement())
  nombre    String
  correo    String?
  cif       String   @default("")
  telefono  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses  Expense[]
}

enum ExpenseType {
  GENERAL
  INDUSTRIAL
  MATERIALES
  SERVICIOS
  PERSONAL
}

model Expense {
  id               Int         @id @default(autoincrement())
  tipo             ExpenseType
  concepto         String?
  importe          Float?
  fecha            DateTime?
  numero           String?
  fechaVencimiento DateTime?
  pdfUrl           String?
  horas            Float?
  observaciones    String?     @db.Text
  
  estadoPago       String      @default("Pendiente")
  formaPago        String?
  esGastoB         Boolean     @default(false)
  imagenUrl        String?
  
  projectId        Int
  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  bankId           Int?
  bank             Bank?       @relation(fields: [bankId], references: [id])

  workerId         Int?
  worker           Worker?     @relation(fields: [workerId], references: [id])

  supplierId       Int?
  supplier         Supplier?   @relation(fields: [supplierId], references: [id])

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  accion    String
  usuario   String
  detalles  String   @db.Text
  createdAt DateTime @default(now())
}

model Certification {
  id           Int      @id @default(autoincrement())
  importe      Float
  numero       String
  concepto     String
  enviadaOdoo  Boolean  @default(false)
  
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
